<div class="wotitem" id="item_<%= tweet.id %>">
  <div class="likes">
    <span class="numlikes" id="showLikes_<%= tweet.id %>"><%= tweet.likes || 0 %></span>
    <span class="smallfont">likes</span>
    <div class="button_to">
      <%= button_to "like", like_tweet_path(tweet), method: :put %>
    </div>
  </div>

  <div class="item">
    <h4><em><%= tweet.author %></em> · <%= tweet.created_at.strftime("%H:%M") %></h4>
    <p><%= tweet.content %></p>
  </div>
</div>
